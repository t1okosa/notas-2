# Registro privado de paquetes @apolo en Azure Artifacts
# Autenticacion: configura el token via variable de entorno NPM_TOKEN o ejecuta:
# npx -y vsts-npm-auth -config .npmrc
@apolo:registry=https://pkgs.dev.azure.com/RFCSPowerPlatform/PowerPlatform.React/_packaging/apolo-packages/npm/registry/
always-auth=true
