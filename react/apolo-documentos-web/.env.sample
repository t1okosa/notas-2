# Dev local con mocks activados (monta mockApiClient, auto-llena saleId, omite rewrite del titulo D365)
VITE_APP_MODO_LOCAL=false

# URL del worker de pdfjs. En dev queda servido por Vite en /pdf.work.min.js.
# Al publicar en CRM override a: /WebResources/axx_/Html/Documentos/ModalPdf/pdf.work.min.js
VITE_PDF_WORKER_URL=/pdf.work.min.js

# URL base para los cMaps de pdfjs (fuentes CID: asiaticas y algunos
# encodings legacy). Los archivos los sincroniza scripts/sync-pdfjs-assets.mjs
# a public/pdf-cmaps/. En CRM override al path del webresource equivalente.
VITE_PDF_CMAP_URL=/pdf-cmaps/

# URL base para las 14 fuentes estandar (Helvetica, Times, Courier, Symbol,
# ZapfDingbats). pdfjs 3.x NO las embebe — sin esta config los PDFs que las
# referencian se renderizan con glifos vacios. Los archivos los sincroniza
# scripts/sync-pdfjs-assets.mjs a public/pdf-fonts/.
VITE_PDF_FONTS_URL=/pdf-fonts/
